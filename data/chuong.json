<!DOCTYPE html>
<html lang="vi">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width,initial-scale=1">
<title>Đọc Chương — LN Kattobi</title>
<link rel="stylesheet" href="css/style.css">
<link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css">
<style>
.progress-bar { position:fixed; top:0; left:0; right:0; height:3px; z-index:9999; }
.progress-fill { height:100%; background:var(--orange); width:0%; transition:width .15s; }

.reader-wrap { max-width:820px; margin:0 auto; padding:16px; }
.reader-wrap.rw-narrow { max-width:600px; }
.reader-wrap.rw-wide   { max-width:1060px; }

.breadcrumb { font-size:.82rem; color:var(--muted); display:flex; align-items:center; gap:6px; flex-wrap:wrap; margin-bottom:14px; }
.breadcrumb a { color:var(--muted); }
.breadcrumb a:hover { color:var(--orange); }
.breadcrumb .sep { color:var(--muted2); }
.breadcrumb .cur { color:var(--text); font-weight:600; }

/* ── FLOATING SETTINGS BUTTON ── */
.settings-float {
  position: fixed; bottom: 80px; right: 20px; z-index: 800;
  width: 48px; height: 48px; border-radius: 50%;
  background: #2c3e50; color: #fff; border: none;
  font-size: 1.2rem; cursor: pointer;
  box-shadow: 0 4px 16px rgba(0,0,0,.3);
  display: flex; align-items: center; justify-content: center;
  transition: transform .2s, background .2s;
}
.settings-float:hover { background: var(--orange); transform: scale(1.08) rotate(30deg); }

/* ── SETTINGS PANEL ── */
.settings-panel {
  position: fixed; bottom: 140px; right: 20px; z-index: 801;
  width: 320px;
  background: #1e2433;
  border-radius: 10px;
  box-shadow: 0 8px 32px rgba(0,0,0,.5);
  padding: 0;
  display: none;
  overflow: hidden;
}
.settings-panel.open { display: block; animation: panelIn .2s ease; }
@keyframes panelIn { from{opacity:0;transform:translateY(10px)} to{opacity:1;transform:translateY(0)} }

/* Nav row inside panel */
.sp-nav {
  display: grid; grid-template-columns: repeat(4,1fr);
  border-bottom: 1px solid rgba(255,255,255,.08);
}
.sp-nav-btn {
  background: none; border: none; border-right: 1px solid rgba(255,255,255,.08);
  color: rgba(255,255,255,.7); padding: 14px 0;
  font-size: 1rem; cursor: pointer;
  transition: background .15s, color .15s;
  display: flex; align-items: center; justify-content: center;
}
.sp-nav-btn:last-child { border-right: none; }
.sp-nav-btn:hover { background: rgba(255,255,255,.08); color: #fff; }
.sp-nav-btn:disabled { opacity: .3; cursor: default; }

/* Font buttons */
.sp-fonts {
  display: grid; grid-template-columns: repeat(4,1fr);
  gap: 1px; background: rgba(255,255,255,.06);
  border-bottom: 1px solid rgba(255,255,255,.08);
}
.sp-font-btn {
  background: #1e2433; border: none;
  color: rgba(255,255,255,.7);
  padding: 12px 6px; font-size: .82rem; font-weight: 700;
  cursor: pointer; text-align: center;
  transition: background .15s, color .15s;
}
.sp-font-btn:hover { background: rgba(255,255,255,.08); color: #fff; }
.sp-font-btn.on { background: var(--orange); color: #fff; }
.sp-font-btn.ff-serif   { font-family: Georgia, serif; }
.sp-font-btn.ff-roboto  { font-family: "Roboto", sans-serif; }
.sp-font-btn.ff-lora    { font-family: "Lora", Georgia, serif; }

/* Font size slider row */
.sp-size {
  padding: 14px 16px;
  border-bottom: 1px solid rgba(255,255,255,.08);
}
.sp-size-row {
  display: flex; align-items: center; gap: 10px;
}
.sp-size-label {
  color: rgba(255,255,255,.6); font-size: .88rem; font-weight: 800;
  width: 24px; text-align: center; flex-shrink: 0;
}
.sp-size-slider {
  flex: 1; -webkit-appearance: none; appearance: none;
  height: 4px; background: rgba(255,255,255,.2); border-radius: 2px; outline: none;
  cursor: pointer;
}
.sp-size-slider::-webkit-slider-thumb {
  -webkit-appearance: none; width: 18px; height: 18px;
  border-radius: 50%; background: #00bcd4; cursor: pointer;
  box-shadow: 0 0 6px rgba(0,188,212,.5);
}
.sp-size-ticks {
  display: flex; justify-content: space-between;
  padding: 4px 2px 0;
}
.sp-size-ticks span {
  font-size: .68rem; color: rgba(255,255,255,.35);
  width: 24px; text-align: center;
}
.sp-size-ticks span.cur-tick { color: #00bcd4; font-weight: 700; }

/* Chapter selector row */
.sp-chapter {
  padding: 12px 14px;
  display: flex; gap: 8px; align-items: center;
}
.sp-chap-select {
  flex: 1; background: rgba(255,255,255,.06); border: 1px solid rgba(255,255,255,.1);
  color: #fff; padding: 8px 10px; border-radius: 5px;
  font-size: .82rem; outline: none; cursor: pointer;
}
.sp-chap-go {
  background: #7c4dff; color: #fff; border: none;
  padding: 8px 14px; border-radius: 5px;
  font-size: .82rem; font-weight: 700; cursor: pointer;
  white-space: nowrap;
  transition: background .15s;
}
.sp-chap-go:hover { background: #6a3de0; }

/* ── READER NAV (prev/next) ── */
.reader-nav { display:grid; grid-template-columns:1fr auto 1fr; gap:10px; margin-bottom:12px; }
.nav-btn { background:var(--card); border:1px solid var(--border); color:var(--text); padding:11px 16px; font-size:.88rem; font-weight:700; border-radius:6px; transition:all .15s; display:flex; align-items:center; gap:8px; }
.nav-btn:hover:not(:disabled) { background:var(--orange); color:#fff; border-color:var(--orange); }
.nav-btn:disabled { opacity:.4; cursor:default; }
.nav-btn.prev { justify-content:flex-start; }
.nav-btn.next { justify-content:flex-end; }
.nav-btn.mid  { justify-content:center; min-width:130px; flex-shrink:0; }

/* ── READER BODY ── */
.reader-body {
  background:var(--card); border:1px solid var(--border); border-radius:6px;
  padding:36px 48px; margin-bottom:12px;
  font-size:18px; line-height:1.9; color:var(--text);
  transition:background .3s,color .3s,font-size .2s;
}
.reader-body.th-sepia { background:#f4ead8; color:#3e2c18; border-color:#d4c0a0; }
.reader-body.th-dark  { background:#1a1a1a; color:#c8c8c8; border-color:#333; }
.reader-body.th-green { background:#e8f4e8; color:#1a3a1a; border-color:#b0d0b0; }
.reader-body.ff-serif   { font-family: Georgia, "Times New Roman", serif; }
.reader-body.ff-roboto  { font-family: "Roboto", "Segoe UI", sans-serif; }
.reader-body.ff-lora    { font-family: "Lora", Georgia, serif; }
.reader-body.lh-tight  { line-height:1.55 !important; }
.reader-body.lh-loose  { line-height:2.4  !important; }

.ch-title { font-size:1.5rem; font-weight:900; margin-bottom:6px; }
.ch-meta { font-size:.84rem; color:var(--muted); padding-bottom:20px; margin-bottom:24px; border-bottom:1px solid var(--border2); display:flex; gap:16px; flex-wrap:wrap; }
.ch-meta i { margin-right:4px; color:var(--orange); }
.ch-body p { margin-bottom:1.3em; text-indent:2em; }

/* ── COMMENTS ── */
.cmt-box { background:var(--card); border:1px solid var(--border); border-radius:6px; margin-bottom:80px; }
.cmt-head { padding:12px 16px; border-bottom:1px solid var(--border); font-weight:800; color:var(--text); display:flex; align-items:center; gap:8px; }
.cmt-head i { color:var(--orange); }

/* ── TOP NAV BAR ── */
.top-nav-bar {
  background: var(--card);
  border: 1px solid var(--border);
  border-radius: 6px;
  padding: 10px 16px;
  margin-bottom: 12px;
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 8px;
}
.top-nav-title { min-width: 0; flex: 1; }
.top-nav-story {
  font-size: .88rem; font-weight: 700;
  color: var(--orange);
  white-space: nowrap; overflow: hidden; text-overflow: ellipsis;
}
.top-nav-chap {
  font-size: .82rem; color: var(--text);
  font-weight: 600; margin-top: 2px;
  white-space: nowrap; overflow: hidden; text-overflow: ellipsis;
}
.top-nav-btns {
  display: flex; gap: 6px; flex-shrink: 0;
}
.tnb {
  background: #6a3de0; color: #fff; border: none;
  padding: 9px 16px; border-radius: 5px;
  font-size: .84rem; font-weight: 700;
  cursor: pointer; display: flex; align-items: center; gap: 6px;
  transition: background .15s;
  white-space: nowrap;
}
.tnb:hover { background: #5a2dc0; }
.tnb:disabled { opacity: .4; cursor: default; }
.tnb-icon { background: #6a3de0; padding: 9px 12px; }
.tnb-icon:hover { background: #5a2dc0; }



/* ── BOTTOM NAV (fixed) ── */
.bottom-nav {
  position: fixed; bottom: 0; left: 0; right: 0;
  background: var(--card);
  border-top: 1px solid var(--border);
  padding: 10px 20px;
  display: flex; align-items: center; justify-content: space-between;
  z-index: 700;
  box-shadow: 0 -2px 12px rgba(0,0,0,.08);
}
.bn-link {
  color: var(--muted); font-size: .82rem; font-weight: 600;
  display: flex; align-items: center; gap: 6px;
  text-decoration: none; cursor: pointer; background: none; border: none;
  transition: color .15s;
}
.bn-link:hover { color: var(--orange); }
.bn-link i { font-size: .8rem; }
.bn-center {
  color: var(--muted); font-size: 1rem; cursor: pointer;
  background: none; border: none;
  transition: color .15s;
}
.bn-center:hover { color: var(--orange); }

/* Reader body extra bottom padding for fixed nav */
.reader-body { padding-bottom: 20px; }
.cmt-box { margin-bottom: 70px; }

/* Old reader-nav hidden (replaced by top+bottom) */
.reader-nav { display: none; }

@media (max-width:600px) {
  .reader-body { padding: 20px 16px 20px; }
  .ch-title { font-size: 1.2rem; }
  .top-nav-btns .tnb span { display: none; }
  .settings-panel { width: calc(100vw - 24px); right: 12px; }
  .tts-bar { flex-wrap: wrap; }
}

/* Font families */
.reader-body.ff-default { font-family: -apple-system, "Segoe UI", sans-serif; }
.reader-body.ff-serif    { font-family: "Georgia", "Times New Roman", serif; }
.reader-body.ff-mono     { font-family: "Courier New", monospace; }
.reader-body.ff-rounded  { font-family: "Nunito", "Comic Sans MS", cursive; }
.reader-body.ff-open     { font-family: "Palatino", "Book Antiqua", serif; }

/* Font size fine control */
.reader-body.fs-14 { font-size:14px !important; }
.reader-body.fs-16 { font-size:16px !important; }
.reader-body.fs-18 { font-size:18px !important; }
.reader-body.fs-20 { font-size:20px !important; }
.reader-body.fs-22 { font-size:22px !important; }
.reader-body.fs-24 { font-size:24px !important; }
.reader-body.fs-26 { font-size:26px !important; }
.reader-body.fs-28 { font-size:28px !important; }

/* Line height control */
.reader-body.lh-tight  { line-height: 1.6 !important; }
.reader-body.lh-normal { line-height: 1.9 !important; }
.reader-body.lh-loose  { line-height: 2.4 !important; }

/* Width control */
.reader-wrap.rw-narrow { max-width: 600px; }
.reader-wrap.rw-normal { max-width: 820px; }
.reader-wrap.rw-wide   { max-width: 1060px; }

/* Toolbar rows */
.reader-toolbar { flex-direction: column; align-items: stretch; gap: 10px; padding: 12px 16px; }
.tb-row { display: flex; align-items: center; gap: 8px; flex-wrap: wrap; }
.tb-row .tb-label { min-width: 70px; }
.font-preview { font-size: .88rem; padding: 5px 14px; }
.font-preview.serif   { font-family: Georgia, serif; }
.font-preview.mono    { font-family: "Courier New", monospace; }
.font-preview.rounded { font-family: "Nunito", cursive; }
.font-preview.open    { font-family: Palatino, serif; }
.font-size-display {
  background: var(--bg); border: 1px solid var(--border);
  padding: 5px 14px; border-radius: 4px; font-weight: 800;
  font-size: .9rem; min-width: 52px; text-align: center; color: var(--text);
}
.line-h-btn { min-width: 80px; text-align: center; }

@media (max-width:600px) {
  .reader-body { padding:20px 16px; }
  .ch-title { font-size:1.2rem; }
  .reader-nav { grid-template-columns:1fr 1fr; }
  .nav-btn.mid { display:none; }
}
</style>
</head>
<body>

<div class="progress-bar"><div class="progress-fill" id="pf"></div></div>

<div id="hdr"></div>
<div class="reader-wrap">
  <!-- BREADCRUMB -->
  <div id="bc"></div>

  <!-- TOP NAV BAR (like in screenshot) -->
  <div class="top-nav-bar" id="top-nav">
    <div class="top-nav-title">
      <div class="top-nav-story" id="tn-story">—</div>
      <div class="top-nav-chap" id="tn-chap">—</div>
    </div>
    <div class="top-nav-btns">
      <button class="tnb" id="pb" onclick="go(-1)"><i class="fas fa-chevron-left"></i> <span>TRƯỚC</span></button>
      <button class="tnb tnb-icon" onclick="toggleBookmark()" title="Đánh dấu"><i class="fas fa-bookmark"></i></button>
      <button class="tnb tnb-icon" onclick="togglePanel()" title="Cài đặt"><i class="fas fa-cog" id="cog-icon"></i></button>
      <button class="tnb tnb-icon" onclick="location.href='index.html'" title="Trang chủ"><i class="fas fa-home"></i></button>
      <button class="tnb" id="nb" onclick="go(1)"><span>SAU</span> <i class="fas fa-chevron-right"></i></button>
    </div>
  </div>

  <!-- FLOATING SETTINGS BUTTON -->
  <button class="settings-float" onclick="togglePanel()" title="Tùy chỉnh">
    <i class="fas fa-cog" id="cog-icon2"></i>
  </button>

  <!-- SETTINGS PANEL -->
  <div class="settings-panel" id="settings-panel">
    <div class="sp-nav">
      <button class="sp-nav-btn" onclick="go(-1)" title="Chương trước"><i class="fas fa-chevron-left"></i></button>
      <button class="sp-nav-btn" onclick="location.href='index.html'"><i class="fas fa-home"></i></button>
      <button class="sp-nav-btn" onclick="toggleDark()"><i class="fas fa-moon"></i></button>
      <button class="sp-nav-btn" onclick="go(1)"><i class="fas fa-chevron-right"></i></button>
    </div>
    <div class="sp-fonts">
      <button class="sp-font-btn on" id="ff-default" onclick="setFontFamily('default')">Default</button>
      <button class="sp-font-btn ff-serif" id="ff-serif" onclick="setFontFamily('serif')">Serif</button>
      <button class="sp-font-btn ff-roboto" id="ff-roboto" onclick="setFontFamily('roboto')">Roboto</button>
      <button class="sp-font-btn ff-lora" id="ff-lora" onclick="setFontFamily('lora')">Lora</button>
    </div>
    <div class="sp-size">
      <div class="sp-size-row">
        <span class="sp-size-label" style="font-size:.78rem;font-weight:800">A<sup>−</sup></span>
        <input type="range" class="sp-size-slider" id="size-slider"
          min="14" max="28" step="2" value="18"
          oninput="setFontSize(parseInt(this.value))">
        <span class="sp-size-label" style="font-size:1rem;font-weight:800">A<sup>+</sup></span>
      </div>
      <div class="sp-size-ticks" id="size-ticks">
        <span>14</span><span>16</span><span>18</span>
        <span>20</span><span>22</span><span>24</span>
        <span>26</span><span>28</span>
      </div>
    </div>
    <div class="sp-chapter">
      <select class="sp-chap-select" id="csel"></select>
      <button class="sp-chap-go" onclick="goChap(document.getElementById('csel').value)">Chọn chương</button>
    </div>
  </div>

  <!-- Progress -->
  <div style="text-align:right;font-size:.8rem;font-weight:700;color:var(--orange);margin-bottom:8px">
    <span id="pct">0%</span>
  </div>

  <div class="reader-nav"></div>

  <div class="reader-body fs-md" id="rb">
    <div class="loading"><div class="spinner"></div>Đang tải chương...</div>
  </div>

  <div class="reader-nav">
    <button class="nav-btn prev" onclick="go(-1)"><i class="fas fa-chevron-left"></i> Chương trước</button>
    <button class="nav-btn mid" onclick="scrollTo({top:0,behavior:'smooth'})"><i class="fas fa-arrow-up"></i> Lên đầu</button>
    <button class="nav-btn next" onclick="go(1)">Chương sau <i class="fas fa-chevron-right"></i></button>
  </div>

  <div class="cmt-box">
    <div class="cmt-head"><i class="fas fa-comments"></i> Bình Luận Chương</div>
    <div style="padding:20px">
      <div id="disqus_thread"></div>
    </div>
  </div>
</div>

<!-- BOTTOM FIXED NAV -->
<div class="bottom-nav">
  <button class="bn-link" onclick="go(-1)"><i class="fas fa-arrow-left"></i> Chương trước</button>
  <button class="bn-center" onclick="location.href='truyen.html?id=' + (t ? t.id : '')"><i class="fas fa-list"></i></button>
  <button class="bn-link" onclick="go(1)">Chương sau <i class="fas fa-arrow-right"></i></button>
</div>

<div id="ftr"></div>

<script src="js/app.js"></script>
<script>
const B = '';
let t = null, cl = [], ci = 0;
let prog = 0;
let curFS = 18, curFF = 'default', curTh = '';
let panelOpen = false;

function togglePanel() {
  panelOpen = !panelOpen;
  const p = document.getElementById('settings-panel');
  const ic = document.getElementById('cog-icon');
  p.classList.toggle('open', panelOpen);
  ic.style.transform = panelOpen ? 'rotate(90deg)' : '';
}
// Close panel on outside click
document.addEventListener('click', e => {
  const panel = document.getElementById('settings-panel');
  const btn   = document.querySelector('.settings-float');
  if (panel && btn && !panel.contains(e.target) && !btn.contains(e.target)) {
    panelOpen = false;
    panel.classList.remove('open');
  }
});



/* ── BOOKMARK ── */
function toggleBookmark() {
  if (!t) return;
  const key = 'bm-' + t.id;
  const cl2 = cl[ci];
  try {
    const bm = { chap: ci, ten: cl2.ten, so: cl2.so };
    localStorage.setItem(key, JSON.stringify(bm));
    // Flash feedback
    const btn = document.querySelector('.tnb-icon[onclick*="Bookmark"]') ||
      document.querySelector('[onclick*="toggleBookmark"]');
    if (btn) {
      btn.style.background = '#10b981';
      setTimeout(() => btn.style.background = '', 1000);
    }
  } catch(e) {}
}

async function boot() {
  document.getElementById('hdr').innerHTML = renderHeader('', B);
  document.getElementById('ftr').innerHTML = renderFooter(B);
  initDark();
  try {
    const sfs = localStorage.getItem('r-fs');
    const sff = localStorage.getItem('r-ff');
    const sth = localStorage.getItem('r-th');
    if (sfs) curFS = parseInt(sfs);
    if (sff) curFF = sff;
    if (sth !== null) curTh = sth;
  } catch(e) {}
  applyAll();

  const tid = getParam('truyen'), so = getParam('so');
  if (!tid) { err('Thiếu tham số.'); return; }
  try {
    const [all, chaps] = await Promise.all([loadJSON('data/truyen.json'), loadJSON('data/chuong.json')]);
    t = all.find(x => x.id === tid);
    if (!t) { err('Không tìm thấy truyện.'); return; }
    const cd = chaps[tid]; cl = cd ? cd.chuong : [];
    if (!cl.length) { err('Truyện chưa có chương nào.'); return; }
    ci = cl.findIndex(c => c.so == so); if (ci < 0) ci = 0;
    const sel = document.getElementById('csel');
    cl.forEach((c,i) => { const o = document.createElement('option'); o.value=i; o.text=c.ten; if(i===ci) o.selected=true; sel.appendChild(o); });
    render();
  } catch(e) { err('Lỗi: ' + e.message); }
}

function render() {
  const c = cl[ci];
  document.title = c.ten + ' — ' + t.ten + ' — LN Kattobi';
  document.getElementById('bc').innerHTML =
    `<div class="breadcrumb">
      <a href="index.html"><i class="fas fa-home"></i> Trang chủ</a>
      <span class="sep">/</span>
      <a href="truyen.html?id=${t.id}">${t.ten}</a>
      <span class="sep">/</span>
      <span class="cur">${c.ten}</span>
    </div>`;
  document.getElementById('rb').innerHTML =
    `<h1 class="ch-title">${c.ten}</h1>
     <div class="ch-meta">
       <span><i class="fas fa-book"></i>${t.ten}</span>
       <span><i class="fas fa-user-pen"></i>${t.tac_gia||'—'}</span>
       <span><i class="fas fa-language"></i>${t.dich_gia||'—'}</span>
     </div>
     <div class="ch-body">${c.noi_dung||'<p>Nội dung chương chưa được cập nhật.</p>'}</div>`;
  // Update top nav
  const tnStory = document.getElementById('tn-story');
  const tnChap  = document.getElementById('tn-chap');
  if (tnStory) tnStory.textContent = t.ten;
  if (tnChap)  tnChap.textContent  = c.ten;
  // Update prev/next buttons
  const pbs = document.querySelectorAll('#pb');
  const nbs = document.querySelectorAll('#nb');
  pbs.forEach(b => b.disabled = ci <= 0);
  nbs.forEach(b => b.disabled = ci >= cl.length - 1);
  document.getElementById('csel').value = ci;
  prog = 0; updateProg();
  history.replaceState(null,'',`chuong.html?truyen=${t.id}&so=${c.so}`);
  loadDisqus('chuong-' + t.id + '-' + c.so);
  scrollTo({top:0,behavior:'smooth'});
}

function go(d) {
  const ni = ci + d;
  if (ni < 0 || ni >= cl.length) return;
  ci = ni; prog = 0; render();
}
function goChap(i) { ci = parseInt(i); render(); toggleSel(); }
function toggleSel() {}

/* ── FONT SIZE ── */
function setFontSize(size) {
  curFS = Math.min(28, Math.max(14, parseInt(size)));
  const rb = document.getElementById('rb'); if (!rb) return;
  rb.style.fontSize = curFS + 'px';
  // update slider
  const sl = document.getElementById('size-slider');
  if (sl) sl.value = curFS;
  // update ticks highlight
  const ticks = document.querySelectorAll('.sp-size-ticks span');
  const vals = [14,16,18,20,22,24,26,28];
  ticks.forEach((tk, i) => tk.classList.toggle('cur-tick', vals[i] === curFS));
  try { localStorage.setItem('r-fs', curFS); } catch(e) {}
}

/* ── FONT FAMILY ── */
function setFontFamily(ff) {
  curFF = ff;
  const rb = document.getElementById('rb'); if (!rb) return;
  rb.classList.remove('ff-serif','ff-roboto','ff-lora');
  if (ff !== 'default') rb.classList.add('ff-' + ff);
  ['default','serif','roboto','lora'].forEach(f => {
    const el = document.getElementById('ff-'+f);
    if (el) el.classList.toggle('on', f === ff);
  });
  try { localStorage.setItem('r-ff', ff); } catch(e) {}
}

/* ── THEME ── */
function setTheme(th) {
  curTh = th;
  const rb = document.getElementById('rb'); if (!rb) return;
  rb.classList.remove('th-sepia','th-dark','th-green');
  if (th) rb.classList.add('th-' + th);
  try { localStorage.setItem('r-th', th); } catch(e) {}
}

/* ── APPLY ALL ── */
function applyAll() {
  setFontSize(curFS);
  setFontFamily(curFF);
  setTheme(curTh);
}

function updateProg() {
  const pf = document.getElementById('pf'); const pt = document.getElementById('pct');
  if (pf) pf.style.width = prog + '%';
  if (pt) pt.textContent = Math.round(prog) + '%';
}

window.addEventListener('scroll', () => {
  const d = document.documentElement;
  const p = d.scrollHeight - d.clientHeight;
  prog = p > 0 ? Math.min(100, d.scrollTop / p * 100) : 0;
  updateProg();
});

document.addEventListener('keydown', e => {
  if (e.target.tagName==='TEXTAREA'||e.target.tagName==='INPUT') return;
  if (e.key==='ArrowLeft') go(-1);
  if (e.key==='ArrowRight') go(1);
});

function loadDisqus(identifier) {
  var SHORTNAME = 'YOUR_SHORTNAME'; // Thay bằng shortname của bạn
  if (SHORTNAME === 'YOUR_SHORTNAME') {
    document.getElementById('disqus_thread').innerHTML =
      '<div style="padding:16px;text-align:center;color:var(--muted);font-size:.88rem;border:1px dashed var(--border);border-radius:5px">' +
      '<i class="fas fa-comments" style="font-size:1.2rem;display:block;margin-bottom:6px;color:var(--muted2)"></i>' +
      'Cài Disqus để bật bình luận<br><a href="thao-luan.html" style="color:var(--orange);font-weight:700">Xem hướng dẫn →</a>' +
      '</div>';
    return;
  }
  window.disqus_config = function() {
    this.page.identifier = identifier;
    this.page.url = window.location.href;
  };
  var d = document, s = d.createElement('script');
  s.src = 'https://' + SHORTNAME + '.disqus.com/embed.js';
  s.setAttribute('data-timestamp', +new Date());
  (d.head || d.body).appendChild(s);
}

function err(msg) {
  document.getElementById('rb').innerHTML =
    `<div style="text-align:center;padding:40px;color:var(--orange)">
      <i class="fas fa-exclamation-circle" style="font-size:1.5rem;display:block;margin-bottom:8px"></i>
      ${msg}<br>
      <a href="index.html" style="color:var(--orange);margin-top:12px;display:inline-block">← Về trang chủ</a>
    </div>`;
}
boot();
</script>
</body>
</html>
